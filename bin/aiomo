#!/usr/bin/env sh
set -eu

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/opencode"
manifest="$config_dir/.omo-profiles.json"

profile="balanced"
profiles="lite balanced max"
if [ -f "$manifest" ]; then
  profile="$(node -e "const fs=require('fs'); const data=JSON.parse(fs.readFileSync(process.argv[1],'utf8')); console.log(data.default_profile || 'balanced')" "$manifest")"
  profiles="$(node -e "const fs=require('fs'); const data=JSON.parse(fs.readFileSync(process.argv[1],'utf8')); console.log((data.profiles || []).join(' '))" "$manifest")"
fi

is_profile() {
  for item in $profiles; do
    if [ "$item" = "$1" ]; then
      return 0
    fi
  done
  return 1
}

show_help() {
  printf '%s\n' "用法：aiomo [编排级别] [opencode 参数...]"
  printf '%s\n' "      aiomo --omo-profile=<编排级别> [opencode 参数...]"
  printf '%s\n' "      aiomo --omo-profile <编排级别> [opencode 参数...]"
  printf '%s\n' ""
  printf '%s\n' "说明：启动 oh-my-openagent 多 agents 编排模式，并在启动前切换对应 OMO 配置。"
  printf '%s\n' "默认级别：$profile"
  printf '%s\n' "可用级别：$(printf '%s' "$profiles" | tr ' ' '、')"
  printf '%s\n' ""
  printf '%s\n' "示例："
  printf '%s\n' "  aiomo"
  printf '%s\n' "  aiomo coding"
  printf '%s\n' "  aiomo --omo-profile=research run \"请分析当前项目\""
  printf '%s\n' "  aiomo -h"
}

warn_resume_session() {
  session_id=""
  prev=""
  for arg in "$@"; do
    case "$prev" in
      -s|--resume) session_id="$arg" ; break ;;
    esac
    prev="$arg"
  done
  if [ -z "$session_id" ]; then return 0; fi

  opcode_config="$1"
  shift
  if [ ! -f "$opcode_config" ]; then return 0; fi

  max_tokens="$(node -e "const fs=require('fs'); try { const c=JSON.parse(fs.readFileSync(process.argv[1],'utf8')); console.log(c.compaction?.max_input_tokens || 120000); } catch(e) { console.log(120000); }" "$opcode_config")" || max_tokens=120000

  db_path="$HOME/.local/share/opencode/opencode.db"
  if [ ! -f "$db_path" ]; then return 0; fi

  if command -v sqlite3 > /dev/null 2>&1; then
    input_tokens="$(sqlite3 "$db_path" "SELECT json_extract(data, '\$.tokens.input') FROM message WHERE session_id = '$session_id' AND json_extract(data, '\$.role') = 'assistant' ORDER BY time_created DESC LIMIT 1;" 2>/dev/null || echo 0)"
  elif command -v bun > /dev/null 2>&1; then
    input_tokens="$(AIOMO_DB="$db_path" AIOMO_SID="$session_id" bun -e 'import{Database}from"bun:sqlite";const db=new Database(process.env.AIOMO_DB,{readonly:true});try{const r=db.query("select json_extract(data,\"$.tokens.input\") as input from message where session_id=? and json_extract(data,\"$.role\")=\"assistant\" order by time_created desc limit 1").get(process.env.AIOMO_SID);console.log(r?.input??0)}catch(e){console.log(0)}' 2>/dev/null || echo 0)"
  else
    return 0
  fi

  input_tokens="${input_tokens%%[!0-9]*}"
  input_tokens="${input_tokens:-0}"
  if [ "$input_tokens" -gt "$max_tokens" ] 2>/dev/null; then
    printf '\033[33m\n⚠ 旧会话上下文过长：最近输入 token 约 %s，超过 profile max_input_tokens=%s。\n' "$input_tokens" "$max_tokens"
    printf '  建议新开 aiomo 或先对旧会话执行简要之类的压缩后再恢复。\n\033[0m\n'
  fi
}

case "${1:-}" in
  -h|--help)
    show_help
    exit 0
    ;;
esac

case "${1:-}" in
  "") ;;
  *)
    if is_profile "$1"; then
      profile="$1"
      shift
    fi
    ;;
esac

case "${1:-}" in
  "") ;;
  --omo-profile=*)
    profile="${1#--omo-profile=}"
    shift
    ;;
  --omo-profile)
    profile="${2:-}"
    if [ "$#" -ge 2 ]; then
      shift 2
    else
      shift
    fi
    ;;
esac

if ! is_profile "$profile"; then
  printf '%s\n' "不支持的 OMO 编排级别：$profile" >&2
  printf '%s\n' "可用级别：$(printf '%s' "$profiles" | tr ' ' '、')" >&2
  exit 2
fi

opencode_profile_config="$config_dir/opencode.$profile.json"
opencode_active_config="$config_dir/opencode.json"
omo_profile_config="$config_dir/oh-my-openagent.$profile.json"
omo_active_config="$config_dir/oh-my-openagent.json"

if [ ! -f "$opencode_profile_config" ]; then
  printf '%s\n' "缺少 OpenCode 编排级别配置：$opencode_profile_config" >&2
  printf '%s\n' "请先运行：bun run ai:gen -- --force" >&2
  exit 1
fi

if [ ! -f "$omo_profile_config" ]; then
  printf '%s\n' "缺少 OMO 编排级别配置：$omo_profile_config" >&2
  printf '%s\n' "请先运行：bun run ai:gen -- --force" >&2
  exit 1
fi

cp "$opencode_profile_config" "$opencode_active_config"
cp "$omo_profile_config" "$omo_active_config"
warn_resume_session "$opencode_profile_config" "$@"
exec opencode "$@"
