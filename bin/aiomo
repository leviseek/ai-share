#!/usr/bin/env sh
set -eu

config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/opencode"
manifest="$config_dir/.omo-profiles.json"

. "$(dirname "$0")/opencode-launcher-common.sh"
opencode_apply_proxy_env "$config_dir"

profile="balanced"
profiles="lite balanced max"
if [ -f "$manifest" ]; then
  profile="$(node -e "const fs=require('fs'); const data=JSON.parse(fs.readFileSync(process.argv[1],'utf8')); console.log(data.default_profile || 'balanced')" "$manifest")"
  profiles="$(node -e "const fs=require('fs'); const data=JSON.parse(fs.readFileSync(process.argv[1],'utf8')); console.log((data.profiles || []).join(' '))" "$manifest")"
fi

is_profile() {
  for item in $profiles; do
    if [ "$item" = "$1" ]; then
      return 0
    fi
  done
  return 1
}

show_help() {
  printf '%s\n' "用法："
  printf '%s\n' "  aiomo [编排级别] [opencode 参数...]"
  printf '%s\n' "  aiomo --omo-profile=<编排级别> [opencode 参数...]"
  printf '%s\n' "  aiomo --omo-profile <编排级别> [opencode 参数...]"
  printf '%s\n' "  aiomo doctor gitignore [--apply]"
  printf '%s\n' "  aiomo doctor terminal [--launch]"
  printf '%s\n' "  aiomo doctor install"
  printf '%s\n' ""
  printf '%s\n' "说明：启动 oh-my-openagent 多 agents 编排模式，并在启动前切换对应 OMO 配置。"
  printf '%s\n' "默认级别：$profile"
  printf '%s\n' "可用级别：$(printf '%s' "$profiles" | tr ' ' '、')"
  printf '%s\n' ""
  printf '%s\n' "参数："
  printf '%s\n' "  --no-pet                  不启动 Live2D pet 桌面宠物。"
  printf '%s\n' "  doctor gitignore [--apply] 检查 .gitignore 缺失规则；加 --apply 自动追加。"
  printf '%s\n' "  doctor terminal [--launch] 输出自动熔断后终端恢复的手工验证步骤；加 --launch 直接启动 aiomo。"
  printf '%s\n' "  doctor install            检查共享配置、插件、skills 和 TUI 插件是否安装并可见。"
  printf '%s\n' ""
  printf '%s\n' "示例："
  printf '%s\n' "  aiomo"
  printf '%s\n' "  aiomo coding"
  printf '%s\n' "  aiomo doctor gitignore"
  printf '%s\n' "  aiomo doctor gitignore --apply"
  printf '%s\n' "  aiomo doctor terminal"
  printf '%s\n' "  aiomo doctor terminal --launch"
  printf '%s\n' "  aiomo --omo-profile=research run \"请分析当前项目\""
  printf '%s\n' "  aiomo -h"
}

show_gitignore_doctor_help() {
  printf '%s\n' "用法："
  printf '%s\n' "  aiomo doctor gitignore"
  printf '%s\n' "  aiomo doctor gitignore --apply"
  printf '%s\n' ""
  printf '%s\n' "说明："
  printf '%s\n' "  在当前 Git 仓库检查 .gitignore 缺失规则。"
  printf '%s\n' "  默认只输出建议，不修改文件；加 --apply 会把缺失规则追加到 .gitignore。"
}

show_terminal_doctor_help() {
  printf '%s\n' "用法："
  printf '%s\n' "  aiomo doctor terminal"
  printf '%s\n' "  aiomo doctor terminal --launch"
  printf '%s\n' ""
  printf '%s\n' "说明："
  printf '%s\n' "  输出 aiomo 自动熔断后终端恢复的手工验证步骤。"
  printf '%s\n' "  加 --launch 会在输出步骤后直接启动 aiomo。"
}

has_rule() {
  rule="$1"
  file="$2"
  [ -f "$file" ] || return 1
  while IFS= read -r line || [ -n "$line" ]; do
    trimmed=$(printf '%s' "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    case "$trimmed" in
      ""|\#*) ;;
      "$rule") return 0 ;;
    esac
  done < "$file"
  return 1
}

add_rule_once() {
  rule="$1"
  rules="$2"
  case "
$rules
" in
    *"
$rule
"*) printf '%s' "$rules" ;;
    *) printf '%s\n%s' "$rules" "$rule" ;;
  esac
}

gitignore_doctor() {
  apply="false"
  case "${1:-}" in
    -h|--help)
      show_gitignore_doctor_help
      return 0
      ;;
    --apply)
      apply="true"
      ;;
    "") ;;
    *)
      printf '%s\n' "不支持的 doctor gitignore 参数：$1" >&2
      show_gitignore_doctor_help >&2
      return 2
      ;;
  esac

  if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    printf '%s\n' "当前目录不是 Git 仓库，无法执行 doctor gitignore。" >&2
    return 2
  fi

  gitignore_path=".gitignore"
  rules=".opencode/context-guard-alert.json"
  rules=$(add_rule_once ".opencode/context-guard-history/" "$rules")
  rules=$(add_rule_once ".opencode/handoff/" "$rules")
  rules=$(add_rule_once ".opencode/checkpoints/" "$rules")
  rules=$(add_rule_once ".opencode/dcp/" "$rules")
  rules=$(add_rule_once ".opencode/memory/" "$rules")
  rules=$(add_rule_once ".opencode-rescue/" "$rules")
  rules=$(add_rule_once ".sisyphus/evidence/" "$rules")
  rules=$(add_rule_once ".env" "$rules")
  rules=$(add_rule_once ".env.*" "$rules")

  if [ -f package.json ] || [ -f bun.lock ] || [ -f pnpm-lock.yaml ] || [ -f yarn.lock ]; then
    for rule in node_modules/ dist/ build/ .next/ .nuxt/ .svelte-kit/ coverage/ .turbo/ .vite/; do
      rules=$(add_rule_once "$rule" "$rules")
    done
  fi
  if [ -f pyproject.toml ] || [ -f requirements.txt ] || [ -f .python-version ]; then
    for rule in .venv/ venv/ __pycache__/ '*.pyc' .pytest_cache/ .mypy_cache/; do
      rules=$(add_rule_once "$rule" "$rules")
    done
  fi
  if [ -f Cargo.toml ]; then
    rules=$(add_rule_once "target/" "$rules")
  fi
  if [ -f go.mod ]; then
    rules=$(add_rule_once "bin/" "$rules")
    rules=$(add_rule_once ".coverprofile" "$rules")
  fi
  if [ -f pom.xml ] || [ -f build.gradle ] || [ -f build.gradle.kts ]; then
    rules=$(add_rule_once "target/" "$rules")
    rules=$(add_rule_once ".gradle/" "$rules")
    rules=$(add_rule_once "out/" "$rules")
  fi

  missing=""
  old_ifs=$IFS
  IFS='
'
  for rule in $rules; do
    [ -n "$rule" ] || continue
    if ! has_rule "$rule" "$gitignore_path"; then
      missing=$(add_rule_once "$rule" "$missing")
    fi
  done
  IFS=$old_ifs

  if [ -z "$missing" ]; then
    printf '%s\n' "gitignore doctor：未发现缺失规则。"
    return 0
  fi

  printf '%s\n' "gitignore doctor：发现缺失规则："
  IFS='
'
  for rule in $missing; do
    [ -n "$rule" ] && printf '%s\n' "  - $rule"
  done
  IFS=$old_ifs

  if [ "$apply" != "true" ]; then
    printf '%s\n' ""
    printf '%s\n' "仅建议模式（未修改）。如需写入请运行：aiomo doctor gitignore --apply"
    return 0
  fi

  if [ -f "$gitignore_path" ] && [ -s "$gitignore_path" ]; then
    last_char=$(tail -c 1 "$gitignore_path")
    [ -n "$last_char" ] && printf '\n' >> "$gitignore_path"
    last_line=$(tail -n 1 "$gitignore_path")
    [ -n "$last_line" ] && printf '\n' >> "$gitignore_path"
  fi
  printf '%s\n' "# aiomo doctor gitignore" >> "$gitignore_path"
  IFS='
'
  for rule in $missing; do
    [ -n "$rule" ] && printf '%s\n' "$rule" >> "$gitignore_path"
  done
  IFS=$old_ifs
  printf '%s\n' "已追加到 .gitignore：$gitignore_path"
}

terminal_doctor() {
  launch="false"
  case "${1:-}" in
    -h|--help)
      show_terminal_doctor_help
      return 0
      ;;
    --launch)
      launch="true"
      ;;
    "") ;;
  esac

  printf '%s\n' "aiomo 终端恢复验证步骤"
  printf '%s\n' ""
  printf '%s\n' "目标：确认自动熔断后退出 TUI 回到 pwsh 时，移动鼠标不会再向终端刷 0x233... 一类乱码。"
  printf '%s\n' ""
  printf '%s\n' "前置条件："
  printf '%s\n' "1. 已执行过：bun run ai:gen -- --force"
  printf '%s\n' "2. 最新 launcher 已安装到：$HOME/.local/bin"
  printf '%s\n' "3. 关闭所有残留的 aiomo、opencode.exe、live2d-pet.exe 进程。"
  printf '%s\n' "4. 用一个新的 pwsh 窗口执行验证。"
  printf '%s\n' ""
  printf '%s\n' "手工验证步骤："
  printf '%s\n' "1. 运行：aiomo"
  printf '%s\n' "2. 进入 TUI 后，执行一个会明显拉长会话的操作，直到触发自动熔断。"
  printf '%s\n' "3. 观察它退出后是否回到 pwsh 提示符。"
  printf '%s\n' "4. 在 pwsh 里移动鼠标 5 秒。"
  printf '%s\n' "5. 期望：终端只改变光标位置，不再持续输出控制字符或 0x233... 乱码。"
  printf '%s\n' "6. 如果仍有乱码，记录 aiomo profile、触发方式、session id 和终端类型。"
  printf '%s\n' ""
  printf '%s\n' "建议记录项："
  printf '%s\n' "- aiomo profile"
  printf '%s\n' "- 触发熔断时的 session id"
  printf '%s\n' "- Windows Terminal / 旧版 console host / VS Code terminal"
  printf '%s\n' "- 乱码是否只在鼠标移动时出现"

  if [ "$launch" = "true" ]; then
    printf '%s\n' ""
    printf '%s\n' "正在启动 aiomo，退出后请按上面步骤手工验证。"
    aiomo
  fi
}

case "${1:-}" in
  -h|--help)
    show_help
    exit 0
    ;;
  doctor)
    case "${2:-}" in
      gitignore)
        gitignore_doctor "${3:-}"
        exit "$?"
        ;;
      terminal)
        terminal_doctor "${3:-}"
        exit "$?"
        ;;
      install)
        doctor_script="$(dirname "$0")/opencode-install-doctor.ts"
        if [ ! -f "$doctor_script" ]; then
          printf '%s\n' "缺少 install doctor 脚本：$doctor_script" >&2
          exit 1
        fi
        if ! command -v bun >/dev/null 2>&1; then
          printf '%s\n' "缺少 bun，无法执行 doctor install。" >&2
          exit 1
        fi
        opencode_profile_config="$config_dir/profiles/opencode/$profile.json"
        opencode_active_config="$config_dir/opencode.json"
        omo_profile_config="$config_dir/profiles/oh-my-openagent/$profile.json"
        omo_active_config="$config_dir/oh-my-openagent.json"
        strategy_profile_config="$config_dir/profiles/strategy/$profile.json"
        strategy_active_config="$config_dir/strategy.json"
        context_guard_profile_config="$config_dir/profiles/context-guard/$profile.json"
        context_guard_active_profile_config="$config_dir/context-guard.profile.json"
        if [ -f "$opencode_profile_config" ]; then
          cp "$opencode_profile_config" "$opencode_active_config"
        fi
        if [ -f "$omo_profile_config" ]; then
          cp "$omo_profile_config" "$omo_active_config"
        fi
        if [ -f "$strategy_profile_config" ]; then
          cp "$strategy_profile_config" "$strategy_active_config"
        fi
        if [ -f "$context_guard_profile_config" ]; then
          cp "$context_guard_profile_config" "$context_guard_active_profile_config"
        fi
        bun "$doctor_script" aiomo "$profile"
        exit "$?"
        ;;
      *)
        printf '%s\n' "用法：aiomo doctor gitignore [--apply]" >&2
        printf '%s\n' "用法：aiomo doctor terminal [--launch]" >&2
        printf '%s\n' "用法：aiomo doctor install" >&2
        exit 2
        ;;
    esac
    ;;
  rescue)
    if [ "$#" -lt 2 ]; then printf '%s\n' "用法：aiomo rescue <session-id>" >&2; exit 2; fi
    opencode_context_guard rescue aiomo "$config_dir/profiles/opencode/$profile.json" "$config_dir" "$2"
    exit "$?"
    ;;
esac

case "${1:-}" in
  "") ;;
  *)
    if is_profile "$1"; then
      profile="$1"
      shift
    fi
    ;;
esac

case "${1:-}" in
  "") ;;
  --omo-profile=*)
    profile="${1#--omo-profile=}"
    shift
    ;;
  --omo-profile)
    profile="${2:-}"
    if [ "$#" -ge 2 ]; then
      shift 2
    else
      shift
    fi
    ;;
esac

# Parse --no-pet flag from remaining args
skip_live2d_pet="false"
_rest=""
for _arg in "$@"; do
  case "$_arg" in
    --no-pet) skip_live2d_pet="true" ;;
    *)
      _rest="$_rest${_rest:+ }'$(printf '%s' "$_arg" | sed "s/'/'\\\\''/g")'"
      ;;
  esac
done
eval "set -- $_rest"

if ! is_profile "$profile"; then
  printf '%s\n' "不支持的 OMO 编排级别：$profile" >&2
  printf '%s\n' "可用级别：$(printf '%s' "$profiles" | tr ' ' '、')" >&2
  exit 2
fi

opencode_profile_config="$config_dir/profiles/opencode/$profile.json"
opencode_active_config="$config_dir/opencode.json"
omo_profile_config="$config_dir/profiles/oh-my-openagent/$profile.json"
omo_active_config="$config_dir/oh-my-openagent.json"
strategy_profile_config="$config_dir/profiles/strategy/$profile.json"
strategy_active_config="$config_dir/strategy.json"
context_guard_profile_config="$config_dir/profiles/context-guard/$profile.json"
context_guard_active_profile_config="$config_dir/context-guard.profile.json"

if [ ! -f "$opencode_profile_config" ]; then
  printf '%s\n' "缺少 OpenCode 编排级别配置：$opencode_profile_config" >&2
  printf '%s\n' "请先运行：bun run ai:gen -- --force" >&2
  exit 1
fi

if [ ! -f "$omo_profile_config" ]; then
  printf '%s\n' "缺少 OMO 编排级别配置：$omo_profile_config" >&2
  printf '%s\n' "请先运行：bun run ai:gen -- --force" >&2
  exit 1
fi

cp "$opencode_profile_config" "$opencode_active_config"
cp "$omo_profile_config" "$omo_active_config"
if [ -f "$strategy_profile_config" ]; then
  cp "$strategy_profile_config" "$strategy_active_config"
fi
if [ -f "$context_guard_profile_config" ]; then
  cp "$context_guard_profile_config" "$context_guard_active_profile_config"
fi
guard_budget_config="$opencode_profile_config"
if [ -f "$context_guard_profile_config" ]; then
  guard_budget_config="$context_guard_profile_config"
fi
set +e
opencode_context_guard check aiomo "$guard_budget_config" "$config_dir" "$@"
code="$?"
set -e
if [ "$code" = "10" ]; then exit 10; fi
if [ "$skip_live2d_pet" = "false" ]; then
  opencode_live2d_pet_start "$config_dir"
fi

# Start opencode in background so we can capture its PID for context-guard watch
opencode "$@" &
opencode_pid=$!

# Forward signals to opencode before cleanup — without this, background+wait
# would trap SIGINT/SIGTERM in the launcher shell itself, skipping opencode's
# graceful signal handler (signals.ts) and leaving the terminal in TUI raw mode.
trap 'kill -TERM $opencode_pid 2>/dev/null; exit 143' TERM
trap 'kill -HUP  $opencode_pid 2>/dev/null; exit 129' HUP
trap 'kill -INT  $opencode_pid 2>/dev/null; exit 130' INT

# EXIT trap fires on any exit (normal or signal-forwarded) — restores terminal
if [ "$skip_live2d_pet" = "false" ]; then
  trap 'opencode_restore_terminal; opencode_live2d_pet_stop' EXIT
else
  trap 'opencode_restore_terminal' EXIT
fi

# Pass opencode PID (not $$) to watch — stopProcessTree will SIGTERM opencode directly
opencode_context_guard_watch aiomo "$guard_budget_config" "$config_dir" "$(pwd)" "$opencode_pid"

# Wait for opencode to finish
wait $opencode_pid
status=$?

opencode_restore_terminal
if [ "$skip_live2d_pet" = "false" ]; then
  opencode_live2d_pet_stop
fi
trap - EXIT HUP INT TERM
exit "$status"
