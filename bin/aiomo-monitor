#!/usr/bin/env sh
set -eu

if command -v powershell.exe >/dev/null 2>&1; then
  SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
  exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$SCRIPT_DIR/aiomo-monitor.ps1" "$@"
fi

printf '%s\n' "aiomo-monitor 当前仅内置 Windows 独立浮窗实现。"
printf '%s\n' "请在 Windows PowerShell 中执行: aiomo-monitor"
