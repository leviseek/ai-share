#!/usr/bin/env sh
set -eu

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/opencode"
MANIFEST="$CONFIG_DIR/.omo-profiles.json"
PROFILE="balanced"
PROFILES="lite balanced max"

. "$(dirname "$0")/opencode-launcher-common.sh"
opencode_apply_proxy_env "$CONFIG_DIR"

if [ -f "$MANIFEST" ]; then
  PROFILE="$(node -e "const fs=require('fs'); const m=JSON.parse(fs.readFileSync(process.argv[1], 'utf8')); process.stdout.write(String(m.default_profile || 'balanced'))" "$MANIFEST")"
  PROFILES="$(node -e "const fs=require('fs'); const m=JSON.parse(fs.readFileSync(process.argv[1], 'utf8')); process.stdout.write(Array.isArray(m.profiles) ? m.profiles.join(' ') : 'lite balanced max')" "$MANIFEST")"
fi

if [ "${1:-}" = "doctor" ]; then
  if [ "${2:-}" != "install" ]; then
    printf '%s\n' "用法：aioc doctor install" >&2
    exit 2
  fi
  doctor_script="$(dirname "$0")/opencode-install-doctor.ts"
  if [ ! -f "$doctor_script" ]; then
    printf '%s\n' "缺少 install doctor 脚本：$doctor_script" >&2
    exit 1
  fi
  if ! command -v bun >/dev/null 2>&1; then
    printf '%s\n' "缺少 bun，无法执行 doctor install。" >&2
    exit 1
  fi
  AIOC_CONFIG="$CONFIG_DIR/profiles/aioc/$PROFILE.json"
  ACTIVE_CONFIG="$CONFIG_DIR/opencode.json"
  if [ -f "$AIOC_CONFIG" ]; then
    cp "$AIOC_CONFIG" "$ACTIVE_CONFIG"
  fi
  bun "$doctor_script" aioc "$PROFILE"
  exit "$?"
fi

ARGS=""
if [ "$#" -gt 0 ]; then
  case " $PROFILES " in
    *" $1 "*) PROFILE="$1"; shift ;;
  esac
fi

if [ "$#" -gt 0 ]; then
  case "$1" in
    --profile)
      shift
      PROFILE="${1:-}"
      [ "$#" -gt 0 ] && shift
      ;;
    --profile=*)
      PROFILE="${1#--profile=}"
      shift
      ;;
  esac
fi

case " $PROFILES " in
  *" $PROFILE "*) ;;
  *)
    printf '%s\n' "不支持的 aioc 配置级别：$PROFILE" >&2
    printf '%s\n' "可用级别：$PROFILES" >&2
    exit 2
    ;;
esac

AIOC_CONFIG="$CONFIG_DIR/profiles/aioc/$PROFILE.json"
ACTIVE_CONFIG="$CONFIG_DIR/opencode.json"

if [ ! -f "$AIOC_CONFIG" ]; then
  printf '%s\n' "缺少 aioc OpenCode 配置级别配置：$AIOC_CONFIG" >&2
  printf '%s\n' "请先运行：bun run ai:gen -- --force" >&2
  exit 1
fi

cp "$AIOC_CONFIG" "$ACTIVE_CONFIG"

exec opencode "$@"
