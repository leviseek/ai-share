exports[`generator config snapshots strategy balanced matches snapshot 1`] = `
{
  "$schema": "https://opencode.ai/ai-share-strategy.json",
  "oh_my_openagent": {
    "checkpoint": {
      "enabled": true,
      "max_entries": 20,
      "mode": "agent-session",
      "require_verification_note": true,
      "restore_policy": "manual-only",
      "trigger": "before-edit-and-before-delegation",
    },
    "dcp": {
      "context_budget_tokens": 24000,
      "enabled": true,
      "handoff_policy": "summarize-before-delegate",
      "mode": "shared",
      "required_sections": [
        "task",
        "expected_outcome",
        "required_tools",
        "must_do",
        "must_not_do",
        "context",
      ],
      "share": {
        "decisions": true,
        "plans": true,
        "secrets": false,
        "verification": true,
      },
    },
    "memory": {
      "enabled": true,
      "mode": "shared",
      "read_policy": "load-before-plan",
      "redact": [
        "api_key",
        "token",
        "password",
        "secret",
        "cookie",
      ],
      "scope": "project",
      "strategy": "verified-summary",
      "write_policy": "facts-decisions-and-runbooks-only",
    },
  },
  "opencode": {
    "checkpoint": {
      "enabled": true,
      "exclude": [
        "node_modules/**",
        ".git/**",
        "bun.lock",
      ],
      "include": [
        "config/*.yaml",
        "src/**/*.ts",
        "bin/*",
        "plugins/**",
      ],
      "max_entries": 20,
      "mode": "session",
      "restore_policy": "manual-only",
      "root": ".opencode/checkpoints",
      "trigger": "before-risky-change",
    },
    "dcp": {
      "context_budget_tokens": 24000,
      "enabled": true,
      "exclude": [
        ".env",
        ".env.*",
        "node_modules/**",
        "bun.lock",
        ".git/**",
      ],
      "include": [
        "AI_GUIDELINES.md",
        "GIT_COMMIT_GUIDELINES.md",
        "README.md",
        "config/*.yaml",
        "memory/**",
      ],
      "mode": "shared",
      "root": ".opencode/dcp",
      "secrets_policy": "env-only",
      "strategy": "local-first",
      "sync": "manual",
    },
    "memory": {
      "enabled": true,
      "exclude": [
        ".env",
        ".env.*",
        "node_modules/**",
        ".git/**",
      ],
      "include": [
        "AI_GUIDELINES.md",
        "README.md",
        "config/*.yaml",
        "memory/**",
      ],
      "mode": "shared",
      "redact": [
        "api_key",
        "token",
        "password",
        "secret",
      ],
      "retention": "project",
      "root": ".opencode/memory",
      "strategy": "summary-first",
      "write_policy": "verified-facts-only",
    },
  },
  "profile": "balanced",
  "workspace": {
    "ignore": [
      ".git/**",
      ".opencode/context-guard-watch/**",
      ".opencode/handoff/**",
      ".opencode/checkpoints/**",
      ".opencode/dcp/**",
      ".opencode/memory/**",
      ".opencode-rescue/**",
      ".sisyphus/evidence/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "target/**",
      ".next/**",
      ".nuxt/**",
      ".svelte-kit/**",
      "coverage/**",
      ".cache/**",
      ".turbo/**",
      ".vite/**",
      "bun.lock",
      "package-lock.json",
      "pnpm-lock.yaml",
      "yarn.lock",
      ".env",
      ".env.*",
    ],
  },
}
`;

