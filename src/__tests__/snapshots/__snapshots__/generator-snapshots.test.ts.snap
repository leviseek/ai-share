{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "max_tokens": 8192,
      "mode": "primary",
      "model": "codexapis/gpt-5.4",
    },
    "compaction": {
      "model": "codexapis/gpt-5.4-mini",
    },
    "explore": {
      "max_tokens": 2048,
      "mode": "subagent",
      "model": "codexapis/gpt-5.4-mini",
      "permission": {
        "edit": "deny",
      },
    },
    "general": {
      "max_tokens": 4096,
      "mode": "subagent",
      "model": "codexapis/gpt-5.4",
    },
    "plan": {
      "max_tokens": 4096,
      "mode": "primary",
      "model": "codexapis/gpt-5.4",
      "permission": {
        "bash": "ask",
        "edit": "deny",
      },
    },
    "summary": {
      "model": "codexapis/gpt-5.4-mini",
    },
    "title": {
      "model": "codexapis/gpt-5.4-mini",
    },
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 40000,
  },
  "instructions": [
    "D:\\ai-share\\AI_GUIDELINES.md",
    "D:\\ai-share\\memory\\user\\profile.md",
    "D:\\ai-share\\memory\\user\\profile.yaml",
    "D:\\ai-share\\memory\\user\\workflow.md",
    "D:\\ai-share\\memory\\user\\workflows.yaml",
    "D:\\ai-share\\memory\\user\\preferences.md",
    "D:\\ai-share\\memory\\user\\devices.md",
    "D:\\ai-share\\memory\\user\\devices.yaml",
    "D:\\ai-share\\memory\\user\\toolchain.md",
    "D:\\ai-share\\memory\\user\\prompts.md",
    "D:\\ai-share\\memory\\user\\models.yaml",
    "D:\\ai-share\\memory\\architecture\\coding-philosophy.md",
    "D:\\ai-share\\memory\\architecture\\agent-patterns.md",
    "D:\\ai-share\\memory\\architecture\\ai-desktop.md",
    "D:\\ai-share\\memory\\stack\\opencode.md",
    "D:\\ai-share\\memory\\stack\\oh-my-openagent.md",
    "D:\\ai-share\\memory\\stack\\wsl.md",
    "D:\\ai-share\\memory\\stack\\models.md",
    "D:\\ai-share\\memory\\stable\\user.yaml",
  ],
  "model": "codexapis/gpt-5.4",
  "plugin": [
    "oh-my-openagent@3.17.5",
    "./plugins/omo-agent-monitor",
    "./plugins/dingtalk-notifier",
  ],
  "provider": {
    "codexapis": {
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT 5.3 Codex (CodexAPI)",
        },
        "gpt-5.4": {
          "name": "GPT 5.4 (CodexAPI)",
        },
        "gpt-5.4-mini": {
          "name": "GPT 5.4 Mini (CodexAPI)",
        },
        "gpt-5.5": {
          "name": "GPT 5.5 (CodexAPI)",
        },
      },
      "name": "Codex APIs",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:CODEXAPIS_API_KEY}",
        "baseURL": "https://www.codexapis.com/v1",
        "chunkTimeout": 30000,
        "timeout": 600000,
      },
    },
    "deepseek": {
      "models": {
        "deepseek-v4-flash": {
          "name": "Deepseek V4 Flash (DeepSeek)",
        },
        "deepseek-v4-flash-think": {
          "id": "deepseek-v4-flash",
          "name": "Deepseek V4 Flash Think (DeepSeek)",
          "options": {
            "reasoning_effort": "high",
            "thinking": {
              "type": "enabled",
            },
          },
        },
        "deepseek-v4-pro-think": {
          "id": "deepseek-v4-pro",
          "name": "Deepseek V4 PRO Think (DeepSeek)",
          "options": {
            "reasoning_effort": "high",
            "thinking": {
              "type": "enabled",
            },
          },
        },
        "deepseek-v4-pro-think-max": {
          "id": "deepseek-v4-pro",
          "name": "Deepseek V4 PRO Think MAX (DeepSeek)",
          "options": {
            "reasoning_effort": "max",
            "thinking": {
              "type": "enabled",
            },
          },
        },
      },
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "baseURL": "https://api.deepseek.com",
        "chunkTimeout": 30000,
        "timeout": 600000,
      },
    },
  },
  "small_model": "codexapis/gpt-5.4-mini",
}
`;

