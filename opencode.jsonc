{
  "$schema": "./.vscode/opencode.schema.json",

  // Default shared models. Per-project opencode.jsonc files can override these.
  "model": "codexapis/gpt-5.5",
  "small_model": "codexapis/gpt-5.4-mini",
  "instructions": ["AI_GUIDELINES.md"],
  "plugin": ["oh-my-openagent"],

  "agent": {
    "build": {
      "mode": "primary",
      "model": "codexapis/gpt-5.5"
    },
    "plan": {
      "mode": "primary",
      "model": "codexapis/gpt-5.5",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "general": {
      "mode": "subagent",
      "model": "codexapis/gpt-5.5"
    },
    "explore": {
      "mode": "subagent",
      "model": "codexapis/gpt-5.4-mini",
      "permission": {
        "edit": "deny"
      }
    },
    "compaction": {
      "model": "codexapis/gpt-5.4-mini"
    },
    "title": {
      "model": "codexapis/gpt-5.4-mini"
    },
    "summary": {
      "model": "codexapis/gpt-5.4-mini"
    }
  },

  "provider": {
    "codexapis": {
      "name": "Codex APIs",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://www.codexapis.com/v1",
        "apiKey": "{env:CODEXAPIS_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT-5.2"
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex"
        },
        "gpt-5.2-pro": {
          "name": "GPT-5.2 Pro"
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex"
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark"
        },
        "gpt-5.4": {
          "name": "GPT-5.4"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini"
        },
        "gpt-5.4-openai-compact": {
          "name": "GPT-5.4 OpenAI Compact"
        },
        "gpt-5.5": {
          "name": "GPT-5.5"
        },
        "gpt-5.5-openai-compact": {
          "name": "GPT-5.5 OpenAI Compact"
        }
      }
    },

    "deepseek": {
      "name": "DeepSeek",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 30000
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (no thinking)",
          "options": {
            "thinking": {
              "type": "disabled"
            }
          }
        },
        "deepseek-v4-flash-think-high": {
          "id": "deepseek-v4-flash",
          "name": "DeepSeek V4 Flash (thinking high)",
          "options": {
            "thinking": {
              "type": "enabled"
            },
            "reasoning_effort": "high"
          }
        },
        "deepseek-v4-flash-think-max": {
          "id": "deepseek-v4-flash",
          "name": "DeepSeek V4 Flash (thinking max)",
          "options": {
            "thinking": {
              "type": "enabled"
            },
            "reasoning_effort": "max"
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (no thinking)",
          "options": {
            "thinking": {
              "type": "disabled"
            }
          }
        },
        "deepseek-v4-pro-think-high": {
          "id": "deepseek-v4-pro",
          "name": "DeepSeek V4 Pro (thinking high)",
          "options": {
            "thinking": {
              "type": "enabled"
            },
            "reasoning_effort": "high"
          }
        },
        "deepseek-v4-pro-think-max": {
          "id": "deepseek-v4-pro",
          "name": "DeepSeek V4 Pro (thinking max)",
          "options": {
            "thinking": {
              "type": "enabled"
            },
            "reasoning_effort": "max"
          }
        }
      }
    }
  }
}
