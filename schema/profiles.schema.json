{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "runtime": {
            "type": "string",
            "enum": ["opencode", "openagent", "hybrid"]
          },
          "modules": {
            "type": "array",
            "items": { "type": "string" }
          },
          "agents": {
            "type": "array",
            "items": { "type": "string" }
          },
          "strategy": { "type": "string" },
          "router_policy": { "type": "string" }
        }
      }
    }
  }
}