{
  "name": "ai-share",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ai:check": "bun run ./src/generate-user-config.ts --check",
    "ai:dry-run": "bun run ./src/generate-user-config.ts --dry-run",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run ai:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ai:gen": "bun run ./src/generate-user-config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.2.1",
    "prettier": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.59.0",
    "typescript-language-server": "^5.1.3"
  }
}
